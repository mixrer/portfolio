
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alex Chen — Designer & Developer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glass-bg: rgba(255,255,255,0.45);
    --glass-border: rgba(255,255,255,0.75);
    --glass-shadow: 0 8px 40px rgba(100,120,160,0.13), 0 1.5px 0 rgba(255,255,255,0.9) inset;
    --glass-hover-bg: rgba(255,255,255,0.62);
    --text-primary: #1a1a2e;
    --text-secondary: #5a6480;
    --text-tertiary: #8a93b0;
    --accent: #3a7bff;
    --accent-soft: rgba(58,123,255,0.12);
    --radius-xl: 28px;
    --radius-lg: 20px;
    --radius-md: 14px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #e8edf5;
    color: var(--text-primary);
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ── Animated Background ── */
  .bg-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .bg-canvas::before {
    content: '';
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(ellipse 80% 60% at 20% 10%, rgba(210,225,255,0.85) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 30%, rgba(230,235,255,0.7) 0%, transparent 55%),
      radial-gradient(ellipse 70% 80% at 50% 80%, rgba(200,215,245,0.6) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 10% 70%, rgba(218,228,255,0.5) 0%, transparent 50%),
      linear-gradient(160deg, #dce8f7 0%, #eef2fb 40%, #f5f7fc 70%, #e8eef8 100%);
    animation: bgFloat 18s ease-in-out infinite alternate;
  }

  .bg-canvas::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle 600px at 70% 20%, rgba(180,205,255,0.25) 0%, transparent 70%),
      radial-gradient(circle 400px at 25% 75%, rgba(200,220,255,0.2) 0%, transparent 65%);
    animation: bgFloat2 12s ease-in-out infinite alternate;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: orbFloat 20s ease-in-out infinite;
  }
  .bg-orb:nth-child(1) { width: 500px; height: 500px; background: rgba(140,185,255,0.4); top: -10%; left: 60%; animation-delay: 0s; }
  .bg-orb:nth-child(2) { width: 350px; height: 350px; background: rgba(180,210,255,0.35); top: 50%; left: -5%; animation-delay: -6s; }
  .bg-orb:nth-child(3) { width: 280px; height: 280px; background: rgba(200,225,255,0.3); top: 70%; left: 70%; animation-delay: -12s; }

  @keyframes bgFloat {
    0%   { transform: translate(0,0) rotate(0deg); }
    100% { transform: translate(3%,2%) rotate(3deg); }
  }
  @keyframes bgFloat2 {
    0%   { transform: translate(0,0); }
    100% { transform: translate(-2%,3%); }
  }
  @keyframes orbFloat {
    0%,100% { transform: translate(0,0) scale(1); }
    33%      { transform: translate(30px,-20px) scale(1.05); }
    66%      { transform: translate(-20px,30px) scale(0.97); }
  }

  /* ── Layout ── */
  .page {
    position: relative;
    z-index: 1;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px 100px;
  }

  /* ── Nav ── */
  nav {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    background: rgba(255,255,255,0.52);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.8);
    border-radius: 100px;
    box-shadow: 0 4px 30px rgba(100,130,180,0.12), 0 1px 0 rgba(255,255,255,0.95) inset;
    animation: navIn 0.8s cubic-bezier(0.34,1.56,0.64,1) both;
  }

  @keyframes navIn {
    from { opacity:0; transform: translateX(-50%) translateY(-20px) scale(0.95); }
    to   { opacity:1; transform: translateX(-50%) translateY(0) scale(1); }
  }

  nav a {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 13.5px;
    font-weight: 400;
    letter-spacing: 0.01em;
    padding: 7px 16px;
    border-radius: 100px;
    transition: all 0.2s ease;
  }
  nav a:hover { background: rgba(58,123,255,0.09); color: var(--accent); }
  nav a.active { background: rgba(58,123,255,0.11); color: var(--accent); font-weight: 500; }

  /* ── Glass Card ── */
  .glass {
    background: var(--glass-bg);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--glass-shadow);
    transition: transform 0.35s cubic-bezier(0.34,1.3,0.64,1), box-shadow 0.35s ease, background 0.25s ease;
  }
  .glass:hover {
    background: var(--glass-hover-bg);
    box-shadow: 0 16px 60px rgba(80,110,170,0.16), 0 1.5px 0 rgba(255,255,255,0.95) inset;
    transform: translateY(-3px);
  }

  /* ── Hero ── */
  .hero {
    padding-top: 140px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
    margin-bottom: 20px;
  }

  .hero-card {
    padding: 44px 44px 40px;
    animation: cardIn 0.9s cubic-bezier(0.34,1.3,0.64,1) 0.15s both;
  }

  .hero-card .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 5px 12px;
    border-radius: 100px;
    margin-bottom: 22px;
  }
  .hero-card .eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:0.5; transform:scale(0.8); }
  }

  .hero-card h1 {
    font-size: clamp(34px, 4.5vw, 48px);
    font-weight: 300;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 18px;
  }
  .hero-card h1 span { font-weight: 500; }

  .hero-card p {
    font-size: 15.5px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 32px;
    max-width: 320px;
  }

  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 26px;
    background: var(--accent);
    color: #fff;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(58,123,255,0.35);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(58,123,255,0.45); background: #2a6bef; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: rgba(255,255,255,0.5);
    color: var(--text-secondary);
    font-family: inherit;
    font-size: 14px;
    font-weight: 400;
    border: 1px solid rgba(255,255,255,0.9);
    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.75); color: var(--text-primary); transform: translateY(-2px); }

  /* Hero avatar card */
  .hero-visual {
    animation: cardIn 0.9s cubic-bezier(0.34,1.3,0.64,1) 0.25s both;
    padding: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .avatar-ring {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, #c8d8f8, #a8c4f8, #c0d6ff);
    padding: 3px;
    box-shadow: 0 8px 30px rgba(100,150,255,0.3);
  }
  .avatar-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #d8e8ff 0%, #b8cfff 50%, #d0e2ff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    font-weight: 200;
    color: rgba(58,100,200,0.6);
    letter-spacing: -2px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    width: 100%;
  }
  .stat-item {
    background: rgba(255,255,255,0.4);
    border: 1px solid rgba(255,255,255,0.75);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    text-align: center;
  }
  .stat-item .num { font-size: 22px; font-weight: 500; color: var(--text-primary); letter-spacing: -0.03em; }
  .stat-item .lbl { font-size: 11px; color: var(--text-tertiary); letter-spacing: 0.04em; text-transform: uppercase; margin-top: 2px; }

  .availability-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 400;
  }
  .avail-dot { width: 8px; height: 8px; border-radius: 50%; background: #34c759; box-shadow: 0 0 0 3px rgba(52,199,89,0.2); animation: pulse 2s ease-in-out infinite; }

  @keyframes cardIn {
    from { opacity:0; transform:translateY(30px) scale(0.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }

  /* ── Section Title ── */
  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 16px;
    padding-left: 4px;
  }

  /* ── Work Grid ── */
  .work-section { margin-bottom: 20px; }
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .project-card {
    padding: 28px 30px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 60%);
    pointer-events: none;
    border-radius: inherit;
  }

  .project-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 14px;
  }

  .project-card h3 {
    font-size: 19px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    color: var(--text-primary);
  }
  .project-card p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
    font-weight: 300;
  }

  .project-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 18px;
  }
  .icon-blue { background: linear-gradient(135deg, #dbeaff, #c5daff); }
  .icon-purple { background: linear-gradient(135deg, #e8deff, #d5c8ff); }
  .icon-teal { background: linear-gradient(135deg, #d5f2ee, #b8e8e2); }
  .icon-rose { background: linear-gradient(135deg, #fde2e8, #f9c5d0); }

  .project-arrow {
    position: absolute;
    top: 28px;
    right: 28px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: var(--text-tertiary);
    transition: all 0.2s ease;
  }
  .project-card:hover .project-arrow { background: var(--accent); color: white; border-color: var(--accent); transform: translate(2px,-2px); }

  /* ── Bottom Grid ── */
  .bottom-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  /* Skills */
  .skills-card { padding: 32px 34px; }
  .skills-card h2 { font-size: 20px; font-weight: 500; letter-spacing: -0.02em; margin-bottom: 22px; }

  .skill-group { margin-bottom: 18px; }
  .skill-group:last-child { margin-bottom: 0; }
  .skill-group-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 10px;
  }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .skill-tag {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-secondary);
    background: rgba(255,255,255,0.55);
    border: 1px solid rgba(255,255,255,0.85);
    padding: 6px 14px;
    border-radius: 100px;
    transition: all 0.2s ease;
  }
  .skill-tag:hover { background: rgba(58,123,255,0.08); color: var(--accent); border-color: rgba(58,123,255,0.2); transform: translateY(-1px); }

  /* Contact */
  .contact-card {
    padding: 32px 30px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
  }
  .contact-card h2 { font-size: 20px; font-weight: 500; letter-spacing: -0.02em; margin-bottom: 8px; }
  .contact-card p { font-size: 14px; line-height: 1.6; color: var(--text-secondary); font-weight: 300; }

  .contact-links { display: flex; flex-direction: column; gap: 10px; }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.45);
    border: 1px solid rgba(255,255,255,0.85);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 400;
    transition: all 0.2s ease;
  }
  .contact-link:hover { background: rgba(255,255,255,0.7); color: var(--text-primary); transform: translateX(4px); }
  .contact-link .link-icon { font-size: 16px; width: 20px; text-align: center; }
  .contact-link .link-label { flex: 1; }
  .contact-link .link-arrow { font-size: 12px; color: var(--text-tertiary); }

  /* ── Experience strip ── */
  .exp-strip {
    padding: 28px 32px;
    margin-bottom: 20px;
    display: flex;
    gap: 0;
    align-items: stretch;
    animation: cardIn 0.9s cubic-bezier(0.34,1.3,0.64,1) 0.7s both;
  }

  .exp-item {
    flex: 1;
    padding: 0 24px;
    border-right: 1px solid rgba(200,215,240,0.5);
  }
  .exp-item:first-child { padding-left: 0; }
  .exp-item:last-child { border-right: none; }

  .exp-year { font-size: 11px; color: var(--text-tertiary); font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 6px; }
  .exp-role { font-size: 15px; font-weight: 500; color: var(--text-primary); letter-spacing: -0.01em; margin-bottom: 3px; }
  .exp-co { font-size: 13px; color: var(--text-secondary); font-weight: 300; }

  /* ── Footer ── */
  footer {
    text-align: center;
    padding: 32px 0 0;
    font-size: 13px;
    color: var(--text-tertiary);
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  /* ── Scroll animations ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.34,1.2,0.64,1);
  }
  .reveal.visible { opacity:1; transform:translateY(0); }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .hero { grid-template-columns: 1fr; padding-top: 110px; }
    .work-grid { grid-template-columns: 1fr; }
    .bottom-grid { grid-template-columns: 1fr; }
    .exp-strip { flex-direction: column; gap: 16px; }
    .exp-item { border-right: none; border-bottom: 1px solid rgba(200,215,240,0.5); padding: 0 0 16px; }
    .exp-item:last-child { border-bottom: none; padding-bottom: 0; }
    nav { width: calc(100% - 32px); justify-content: center; }
  }
</style>
</head>
<body>

<div class="bg-canvas">
  <div class="bg-orb"></div>
  <div class="bg-orb"></div>
  <div class="bg-orb"></div>
</div>

<nav>
  <a href="#" class="active">Home</a>
  <a href="#work">Work</a>
  <a href="#about">About</a>
  <a href="#contact">Contact</a>
</nav>

<div class="page">

  <!-- Hero -->
  <section class="hero" id="home">
    <div class="glass hero-card">
      <div class="eyebrow">Available for work</div>
      <h1>Crafting <span>digital</span><br>experiences</h1>
      <p>I'm Alex Chen — a product designer and frontend developer building thoughtful, human-centered interfaces.</p>
      <div class="hero-actions">
        <a href="#work" class="btn-primary">View Work →</a>
        <a href="#contact" class="btn-ghost">Get in touch</a>
      </div>
    </div>
    <div class="glass hero-visual">
      <div class="avatar-ring">
        <div class="avatar-inner">AC</div>
      </div>
      <div class="availability-badge">
        <span class="avail-dot"></span>
        Open to opportunities
      </div>
      <div class="hero-stats">
        <div class="stat-item"><div class="num">6+</div><div class="lbl">Years</div></div>
        <div class="stat-item"><div class="num">40+</div><div class="lbl">Projects</div></div>
        <div class="stat-item"><div class="num">18</div><div class="lbl">Clients</div></div>
        <div class="stat-item"><div class="num">99%</div><div class="lbl">Satisfied</div></div>
      </div>
    </div>
  </section>

  <!-- Experience strip -->
  <div class="glass exp-strip reveal" id="about">
    <div class="exp-item">
      <div class="exp-year">2023 – Present</div>
      <div class="exp-role">Senior Product Designer</div>
      <div class="exp-co">Arc Browser · San Francisco</div>
    </div>
    <div class="exp-item">
      <div class="exp-year">2021 – 2023</div>
      <div class="exp-role">Design Engineer</div>
      <div class="exp-co">Linear · Remote</div>
    </div>
    <div class="exp-item">
      <div class="exp-year">2019 – 2021</div>
      <div class="exp-role">UI/UX Designer</div>
      <div class="exp-co">Figma · San Francisco</div>
    </div>
  </div>

  <!-- Work -->
  <section class="work-section reveal" id="work">
    <div class="section-label">Selected Work</div>
    <div class="work-grid">

      <div class="glass project-card">
        <div class="project-icon icon-blue">🌊</div>
        <div class="project-tag">Product Design</div>
        <h3>Flow — Task Manager</h3>
        <p>Redesigning productivity for the modern knowledge worker. Fluid, calm, and deeply personal.</p>
        <div class="project-arrow">↗</div>
      </div>

      <div class="glass project-card">
        <div class="project-icon icon-purple">✦</div>
        <div class="project-tag">Design System</div>
        <h3>Prism Design System</h3>
        <p>A comprehensive component library serving 200+ engineers across three product lines.</p>
        <div class="project-arrow">↗</div>
      </div>

      <div class="glass project-card">
        <div class="project-icon icon-teal">◎</div>
        <div class="project-tag">Mobile App</div>
        <h3>Calm — Sleep Coach</h3>
        <p>Sleep tracking and wind-down rituals wrapped in a gentle, science-backed interface.</p>
        <div class="project-arrow">↗</div>
      </div>

      <div class="glass project-card">
        <div class="project-icon icon-rose">⬡</div>
        <div class="project-tag">Web Platform</div>
        <h3>Lattice Analytics</h3>
        <p>Real-time data visualization for ops teams. Complex data, made breathtakingly simple.</p>
        <div class="project-arrow">↗</div>
      </div>

    </div>
  </section>

  <!-- Skills + Contact -->
  <div class="bottom-grid reveal">
    <div class="glass skills-card">
      <h2>Capabilities</h2>

      <div class="skill-group">
        <div class="skill-group-label">Design</div>
        <div class="skill-tags">
          <span class="skill-tag">Product Design</span>
          <span class="skill-tag">UX Research</span>
          <span class="skill-tag">Prototyping</span>
          <span class="skill-tag">Figma</span>
          <span class="skill-tag">Motion</span>
        </div>
      </div>

      <div class="skill-group">
        <div class="skill-group-label">Development</div>
        <div class="skill-tags">
          <span class="skill-tag">React</span>
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">CSS / Tailwind</span>
          <span class="skill-tag">Framer</span>
          <span class="skill-tag">Swift UI</span>
        </div>
      </div>

